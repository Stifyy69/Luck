# Required - copy to .env and fill in values
DATABASE_URL=postgresql://user:password@host:5432/dbname
PORT=3000
VITE_API_BASE=http://localhost:3000
APP_ORIGIN=http://localhost:5173
# Comma-separated additional trusted browser origins, if any
CORS_ORIGINS=

# User sessions - generate a unique value of at least 32 characters
USER_SECRET=replace_with_a_unique_32_plus_character_secret

# Admin panel - rotate these before production deploy
ADMIN_USER=your_admin_username
ADMIN_PASS=use_a_long_unique_password
ADMIN_SECRET=use_a_long_random_signing_secret
